# ── EURI AI (text + image generation) ────────────────────────────────────
# Get your free key at: https://euron.one
# Free tier: 200,000 tokens/day
EURI_API_KEY=your_euri_api_key_here


# ── TELEGRAM — AI NEWS BOT ────────────────────────────────────────────────
# How to get a bot token:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the steps
#   3. BotFather will give you a token like: 123456789:ABCdef...
TELEGRAM_AI_BOT_TOKEN=your_ai_bot_token_here

# The Telegram channel where AI news posts will be published.
# Public channel format:  @YourChannelName
# Private channel format: -100xxxxxxxxxx
TELEGRAM_AI_CHANNEL_ID=@your_ai_channel_here


# ── TELEGRAM — BOLLYWOOD BUZZ BOT ─────────────────────────────────────────
TELEGRAM_BOLLYWOOD_BOT_TOKEN=your_bollywood_bot_token_here
TELEGRAM_BOLLYWOOD_CHANNEL_ID=@your_bollywood_channel_here


# ── TELEGRAM — DAILY ASTROLOGY BOT (inactive — fill in when ready) ────────
TELEGRAM_ASTROLOGY_BOT_TOKEN=your_astrology_bot_token_here
TELEGRAM_ASTROLOGY_CHANNEL_ID=@your_astrology_channel_here


# ── TELEGRAM — REVIEWER CHAT ──────────────────────────────────────────────
# Default reviewer chat ID — used by AI News and Bollywood bots.
# Your personal numeric Telegram chat ID (NOT @username).
# How to get it: message @userinfobot on Telegram.
TELEGRAM_REVIEWER_CHAT_ID=your_numeric_chat_id_here

# Per-bot reviewer overrides (optional).
# If set, that bot's posts go to this chat instead of the default above.
# Leave blank to use the default TELEGRAM_REVIEWER_CHAT_ID.
TELEGRAM_ASTROLOGY_REVIEWER_CHAT_ID=your_astrology_reviewer_chat_id_here


# ── DRIK PANCHANG (for Astrology bot) ────────────────────────────────────
# Required for accurate panchang data (tithi, nakshatra, yoga, festivals).
# How to get these:
#   1. Open Chrome → go to drikpanchang.com → log in with Google
#   2. Press F12 → Application → Cookies → www.drikpanchang.com
#   3. Copy the values for _DRIK_SESSION_ID and drik_access_token
# These cookies expire in ~1 year. When scraping fails, refresh them.
DRIK_SESSION_ID=your_drik_session_id_here
DRIK_ACCESS_TOKEN=your_drik_access_token_here
DRIK_GEONAME_ID=1261481


# ── NEWS API (optional) ───────────────────────────────────────────────────
# Supplementary news source. Free tier: 100 requests/day.
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here


# ── REDDIT API (Phase 2 — leave blank for now) ────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=


# ── PATTERN FOR FUTURE BOTS ───────────────────────────────────────────────
# TELEGRAM_<BOT_ID_UPPERCASE>_BOT_TOKEN=
# TELEGRAM_<BOT_ID_UPPERCASE>_CHANNEL_ID=
